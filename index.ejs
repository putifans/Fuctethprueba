<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crypto Faucet</title>
    <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f8f9fc; color: #333; display: flex; justify-content: center; padding: 20px; }
        .container { width: 100%; max-width: 400px; background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
        .card { border: 1px solid #edf2f7; padding: 15px; border-radius: 12px; margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center; }
        .card h3 { margin: 0; font-size: 18px; color: #2d3748; }
        .card p { margin: 5px 0 0; font-size: 13px; color: #718096; }
        .reward-text { font-weight: bold; font-size: 20px; color: #2d3748; }
        input[type="email"] { width: 100%; padding: 12px; margin-bottom: 15px; border: 1px solid #cbd5e0; border-radius: 8px; box-sizing: border-box; }
        .btn-claim { width: 100%; background: #4299e1; color: white; border: none; padding: 15px; border-radius: 10px; font-weight: bold; cursor: pointer; font-size: 16px; }
        .btn-claim:disabled { background: #a0aec0; }
        .timer-active { color: #e53e3e !important; }
    </style>
</head>
<body>

    <script>(function(s){s.dataset.zone='10273227',s.src='https://gizokraijaw.net/vignette.min.js'})([document.documentElement, document.body].filter(Boolean).pop().appendChild(document.createElement('script')))</script>

    <div class="container">
        <div class="card">
            <div>
                <h3 id="status-text">Ready</h3>
                <p>Timer</p>
            </div>
            <span style="color: #48bb78; font-size: 24px;">✔</span>
        </div>

        <div class="card">
            <div>
                <span class="reward-text">0.00000004 ETH</span>
                <p style="color: #48bb78;">+0%</p>
            </div>
        </div>

        <div class="card">
            <div>
                <h3 id="seconds-display">10</h3>
                <p>Seconds</p>
            </div>
            <span style="color: #4299e1; font-size: 24px;">⏰</span>
        </div>

        <div class="card">
            <div>
                <h3><%= claims %>/25</h3>
                <p>Claims Left - Reset 00 UTC</p>
            </div>
            <span style="color: #e53e3e; font-size: 24px;">🧬</span>
        </div>

        <form action="/claim" method="POST" id="faucet-form">
            <input type="email" name="email" placeholder="Introduce tu correo de FaucetPay" required>
            
            <div class="h-captcha" data-sitekey="<%= sitekey %>"></div>
            
            <button type="submit" class="btn-claim" id="claim-button">Collect your reward</button>
        </form>
    </div>

    <script>(function(s){s.dataset.zone='10273232',s.src='https://al5sm.com/tag.min.js'})([document.documentElement, document.body].filter(Boolean).pop().appendChild(document.createElement('script')))</script>

    <script>
        // Lógica del Timer de 10 segundos
        let timeLeft = 10;
        const btn = document.getElementById('claim-button');
        const secDisplay = document.getElementById('seconds-display');
        const statusText = document.getElementById('status-text');

        btn.disabled = true;
        statusText.innerText = "Waiting...";

        const timer = setInterval(() => {
            timeLeft--;
            secDisplay.innerText = timeLeft;
            if (timeLeft <= 0) {
                clearInterval(timer);
                btn.disabled = false;
                secDisplay.innerText = "0";
                statusText.innerText = "Ready";
            }
        }, 1000);
    </script>
</body>
</html>